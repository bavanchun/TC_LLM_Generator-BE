# Database (Supabase PostgreSQL)
DB_URL=jdbc:postgresql://your-host:5432/postgres
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-min-64-chars
ACCESS_TOKEN_EXPIRE=3600000
REFRESH_TOKEN_EXPIRE=604800000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/login-google

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# Mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com

# App URLs
APP_BACKEND_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:3000

# ============================================================
# Grafana Cloud — Observability credentials
#
# Get these from: grafana.com → Your Stack → "Send data" tab
#   → "Connection Details" for each datasource
#
# All three datasources share the same API key.
# Create one at: grafana.com → My Account → API Keys → Add API Key
#   (Role: MetricsPublisher)
# ============================================================

# Prometheus remote write
# Example: https://prometheus-prod-xx-prod-us-east-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-37-prod-ap-southeast-1.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=2938387

# Loki push endpoint
# Example: https://logs-prod-xxx.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-020.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=1464867

# Tempo OTLP gRPC endpoint (include port, no https:// prefix)
# Example: tempo-prod-xx-prod-us-east-0.grafana.net:443
GRAFANA_CLOUD_TEMPO_URL=1459177

# Shared API key for all Grafana Cloud datasources
GRAFANA_CLOUD_API_KEY=glc_eyJvIjoiMTY1MTc5OSIsIm4iOiJxdXJhZXgtcXVyYWV4LXRva2VuIiwiayI6IjFqM01xNnYzY3U0czQ2VDRXUldKMzdIQSIsIm0iOnsiciI6InByb2QtYXAtc291dGhlYXN0LTEifX0
