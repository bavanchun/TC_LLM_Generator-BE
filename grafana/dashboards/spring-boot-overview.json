{
  "title": "TC LLM Generator — System Overview",
  "description": "JVM metrics, HTTP request performance, HikariCP connection pool",
  "tags": ["tc-llm-generator", "spring-boot", "jvm"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "query": "label_values(jvm_memory_used_bytes{application=\"TC_LLM_Generator\"}, instance)",
        "refresh": 2,
        "includeAll": false,
        "label": "Instance"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP Performance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"TC_LLM_Generator\"}[2m])) by (uri, method)",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_requests_seconds_count{application=\"TC_LLM_Generator\", status=~\"5..\"}[2m])) / sum(rate(http_server_requests_seconds_count{application=\"TC_LLM_Generator\"}[2m]))",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"TC_LLM_Generator\"}[2m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"TC_LLM_Generator\"}[2m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"TC_LLM_Generator\"}[2m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "JVM Memory",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"TC_LLM_Generator\", area=\"heap\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"TC_LLM_Generator\", area=\"heap\"}",
          "legendFormat": "Max",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"TC_LLM_Generator\", area=\"heap\"}",
          "legendFormat": "Committed",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Pause Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "s/s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"TC_LLM_Generator\"}[2m])",
          "legendFormat": "{{action}} {{cause}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Connection Pool & Threads",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Max",
          "refId": "D"
        }
      ]
    },
    {
      "id": 8,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 20, "y": 19, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "green", "value": 3600 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "process_uptime_seconds{application=\"TC_LLM_Generator\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    }
  ]
}
