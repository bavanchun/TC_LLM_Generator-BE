{
  "title": "TC LLM Generator — System Overview",
  "description": "JVM metrics, HTTP request performance, HikariCP connection pool",
  "tags": ["tc-llm-generator", "spring-boot", "jvm"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
        "query": "label_values(jvm_memory_used_bytes{job=\"tc-llm-generator\"}, instance)",
        "refresh": 2,
        "includeAll": false,
        "label": "Instance"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP Performance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(spring_security_http_secured_requests_seconds_count{job=\"tc-llm-generator\"}[2m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "1000 * sum(rate(spring_security_http_secured_requests_seconds_sum{job=\"tc-llm-generator\"}[5m])) / sum(rate(spring_security_http_secured_requests_seconds_count{job=\"tc-llm-generator\"}[5m]))",
          "legendFormat": "Avg latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "JVM Memory",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"tc-llm-generator\", area=\"heap\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"tc-llm-generator\", area=\"heap\"}",
          "legendFormat": "Max",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_committed_bytes{job=\"tc-llm-generator\", area=\"heap\"}",
          "legendFormat": "Committed",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Pause Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "s/s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum{job=\"tc-llm-generator\"}[2m]))",
          "legendFormat": "GC pause s/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Connection Pool & Threads",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"tc-llm-generator\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"tc-llm-generator\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"tc-llm-generator\"}",
          "legendFormat": "Pending",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{job=\"tc-llm-generator\"}",
          "legendFormat": "Max",
          "refId": "D"
        }
      ]
    },
    {
      "id": 8,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"tc-llm-generator\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"tc-llm-generator\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"tc-llm-generator\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 20, "y": 19, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 300 },
            { "color": "green", "value": 3600 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=\"tc-llm-generator\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "row",
      "title": "CPU & Error Logs",
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 13,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"tc-llm-generator\"} * 100",
          "legendFormat": "Process CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{job=\"tc-llm-generator\"} * 100",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 14,
      "title": "Error Log Rate (5m)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(logback_events_total{job=\"tc-llm-generator\",level=\"error\"}[5m])) / sum(rate(logback_events_total{job=\"tc-llm-generator\"}[5m])) * 100",
          "legendFormat": "Error log %",
          "refId": "A"
        }
      ]
    }
  ]
}
